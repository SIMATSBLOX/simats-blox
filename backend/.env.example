# Sensor platform (MongoDB + Socket.IO). Add to repo root .env or copy here for reference.
# The main API server reads these from process.env (see backend/src/config/env.js).

MONGODB_URI=mongodb://127.0.0.1:27017/simats_sensors
CLIENT_ORIGIN=http://localhost:5173

# Main server port (existing SIMATS BLOX Express + SQLite auth)
PORT=3847

# Must match between SQLite JWT (server/index.js) and sensor Socket.IO handshake (`backend/src/config/jwt.js`).
# JWT_SECRET=your-long-random-secret
