# Dependencies — reinstall with: npm install
node_modules/

# Production build — recreate with: npm run build
dist/
dist-ssr/

# Vite / bundler caches
.vite/
.cache/

# Test coverage
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment (keep *.example files in repo)
.env
.env.local
.env.*.local

# Local SQLite (keep files on disk; not committed)
server/data/

# OS junk
.DS_Store
Thumbs.db
Desktop.ini
__MACOSX/

# Tooling caches
.turbo/
.eslintcache
*.tsbuildinfo

# IDE — allow committing .vscode/extensions.json if desired
.idea/
.vscode/*
!.vscode/extensions.json
