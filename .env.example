# Copy to .env.local (or export) for local development.

# SQLite auth API (existing)
PORT=3847
JWT_SECRET=change-me-in-production

# Sensor hub (MongoDB + Socket.IO) — optional; without MONGODB_URI only IDE + SQLite API run.
MONGODB_URI=mongodb://127.0.0.1:27017/simats_sensors
CLIENT_ORIGIN=http://localhost:5173

# --- Frontend (Vite) — optional .env.local next to package.json ---
# Leave unset locally: same-origin + dev proxy to PORT above.
# For a split deploy (static app + API host), build with:
#   VITE_API_URL=https://api.yourdomain.com
# Same origin is then used for Socket.IO to that host (configure CORS + CLIENT_ORIGIN on server).
