# =============================================================================
# SERVER (Node — load via repo root when running `npm run server` / `npm run dev:full`)
# =============================================================================
# SQLite: server/data/ide.sqlite (users, projects, sensor_devices, sensor_readings)

# Sensor API storage: local SQLite (default) or Supabase Postgres tables sensor_devices / sensor_readings.
#   SENSOR_DATA_BACKEND=sqlite
#   SENSOR_DATA_BACKEND=supabase
# Supabase mode also requires (server-only, never expose to Vite):
#   SUPABASE_URL=https://xxxx.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=...
# Hashed device keys (ESP32 still sends raw key in x-device-key): min 16 chars, rotate if compromised.
#   DEVICE_KEY_PEPPER=generate-a-long-random-secret

PORT=3847
JWT_SECRET=change-me-in-production

# Supabase human login for /api/devices + Socket.IO: server validates the access token with
# auth.getUser(jwt) using the same service client as below (SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY).
# Optional legacy: SUPABASE_JWT_SECRET is no longer required for dashboard auth.

# Allowed browser origins for Socket.IO (comma-separated in production), e.g. your Vite or CDN URL
CLIENT_ORIGIN=http://localhost:5173

# =============================================================================
# FRONTEND (Vite only — variables must be prefixed with VITE_)
# Copy to .env.local next to package.json. Never put JWT_SECRET or server-only secrets here.
# =============================================================================

# Optional: API + Socket.IO host when the UI is served from a different origin (production).
# Local dev: leave unset; Vite proxies /api and /socket.io to PORT above (vite.config.js).
#   VITE_API_URL=https://your-api.example.com

# Optional: treat a device as offline if no reading for this many milliseconds (default 90000 = 90s).
#   VITE_DEVICE_OFFLINE_AFTER_MS=180000

# Optional: Supabase cloud auth/projects (Settings in the IDE)
#   VITE_SUPABASE_URL=
#   VITE_SUPABASE_ANON_KEY=

# Demo / staging: dashboard + device REST + Socket.IO use Supabase token only; Express Local API UI hidden.
# Restart Vite after changing.
#   VITE_DEMO_SUPABASE_ONLY=true
