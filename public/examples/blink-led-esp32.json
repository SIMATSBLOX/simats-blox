                            },
                            "next": {
                              "block": {
                                "type": "board_digital_write",
                                "id": "#W,LCNXs72;Sg|_#*?/f",
                                "fields": {
                                  "DPIN": 2,
                                  "LEVEL": "LOW"
                                },
                                "next": {
                                  "block": {
                                    "type": "hw_wait",
                                    "id": "({nm~L+2yOUJ@m+l$DJw",
                                    "fields": {
                                      "MS": 500
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
