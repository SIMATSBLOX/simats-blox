                        "type": "board_digital_write",
                        "id": "7ThkK;t.;**JW(OsdSb8",
                        "fields": {
                          "DPIN": 2,
                          "LEVEL": "HIGH"
                        },
                        "next": {
                          "block": {
                            "type": "hw_wait",
                            "id": "`w]-ovFlt||n~H~3y=Z9",
                            "fields": {
