{
  "version": 1,
  "projectName": "Example: Blink LED",
  "boardId": "esp32",
  "description": "Toggles GPIO2 HIGH/LOW every 500 ms (many DevKit boards use GPIO2 for the onboard LED; use another pin if yours differs). MicroPython preview.",
  "blockly": {
    "blocks": {
      "languageVersion": 0,
      "blocks": [
        {
          "type": "esp32_when_starts",
          "id": "$0}dJ!Hp{f0aS%%hbIM:",
          "x": 20,
          "y": 20,
          "next": {
            "block": {
              "type": "board_pin_mode",
              "id": "!dg)Psa;J(J=0Mu-g#a}",
              "fields": {
                "DPIN": 2,
                "MODE": "OUTPUT"
              },
              "next": {
                "block": {
