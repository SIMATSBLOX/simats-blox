{
  "version": 1,
  "projectName": "Example: DHT11 temperature & humidity",
  "boardId": "arduino_uno",
  "description": "DHT11 data pin on digital 2. Install a DHT library (e.g. Adafruit DHT) for a real upload; preview shows generated calls. Prints temp then humidity every 2 s.",
  "blockly": {
    "blocks": {
      "languageVersion": 0,
      "blocks": [
        {
          "type": "board_when_starts",
          "id": ",I84IzQUbf,k^eq@b{}l",
          "x": 20,
          "y": 20,
          "next": {
            "block": {
              "type": "comm_serial_begin",
              "id": "kBc7oU?Q^-5g9m}%7A-l",
              "fields": {
                "BAUD": 9600
              },
              "next": {
                "block": {
                  "type": "hw_forever",
                  "id": "Ms/7iJoBf8MV}P#7hh$9",
                  "inputs": {
                    "DO": {
                      "block": {
                        "type": "comm_serial_println",
                        "id": "j3(TtQzn!sBx8E9|,?Oz",
                        "inputs": {
                          "VAL": {
                            "block": {
                              "type": "sensor_dht_mblock",
                              "id": "#-sm}}Rczrj.v$ik+C+h",
                              "fields": {
                                "DHTFIELD": "TEMP",
                                "DPIN": 2,
                                "TYPE": "DHT11"
                              }
                            }
                          }
                        },
                        "next": {
                          "block": {
                            "type": "comm_serial_println",
                            "id": "o84[6j=p.)Cdl$W.N#wz",
                            "inputs": {
                              "VAL": {
                                "block": {
                                  "type": "sensor_dht_mblock",
                                  "id": "wIoJbo9PiGUFX:${6U.#",
                                  "fields": {
                                    "DHTFIELD": "HUM",
                                    "DPIN": 2,
                                    "TYPE": "DHT11"
                                  }
                                }
                              }
                            },
                            "next": {
                              "block": {
                                "type": "hw_wait",
                                "id": "GZS;cME8rbxoV90)UB_C",
                                "fields": {
                                  "MS": 2000
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}