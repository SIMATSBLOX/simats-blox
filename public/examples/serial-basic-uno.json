{
  "version": 1,
  "projectName": "Example: Serial Monitor (basic)",
  "boardId": "arduino_uno",
  "description": "Opens Serial at 9600 baud and prints a line every 1 s. Open the IDE Serial Monitor at 9600 to see output.",
  "blockly": {
    "blocks": {
      "languageVersion": 0,
      "blocks": [
        {
          "type": "board_when_starts",
          "id": "po9?,$uwndeX[b6vyLUd",
          "x": 20,
          "y": 20,
          "next": {
            "block": {
              "type": "comm_serial_begin",
              "id": "^Svj(KvFde[.1la;Vw)=",
              "fields": {
                "BAUD": 9600
              },
              "next": {
                "block": {
                  "type": "hw_forever",
                  "id": "CwH8o$R-6KPo/])|.R#F",
                  "inputs": {
                    "DO": {
                      "block": {
                        "type": "comm_serial_println",
                        "id": "3ir[us$TL]:lroa2I`N$",
                        "inputs": {
                          "VAL": {
                            "block": {
                              "type": "text",
                              "id": "0s|b~;T=hFy8f3Zs4?*}",
                              "fields": {
                                "TEXT": "Hello from Uno"
                              }
                            }
                          }
                        },
                        "next": {
                          "block": {
                            "type": "hw_wait",
                            "id": "1x|tIJ~tUq.=f0Hikf}7",
                            "fields": {
                              "MS": 1000
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}