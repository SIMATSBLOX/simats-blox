{
  "version": 1,
  "projectName": "Example: IR / line sensor (digital)",
  "boardId": "arduino_uno",
  "description": "Many IR obstacle or line modules are open-collector / active-low; this sketch uses pin 8 with INPUT_PULLUP and prints True/False (True = pin reads HIGH). Adjust pin and polarity for your module.",
  "blockly": {
    "blocks": {
      "languageVersion": 0,
      "blocks": [
        {
          "type": "board_when_starts",
          "id": "LQ{{8#jv]wFd{L.e}2Wv",
          "x": 20,
          "y": 20,
          "next": {
            "block": {
              "type": "comm_serial_begin",
              "id": "eecCEs^5MEJVtUP?zziM",
              "fields": {
                "BAUD": 9600
              },
              "next": {
                "block": {
                  "type": "board_pin_mode",
                  "id": "e;kyF%C(hS#sN-D}2U.@",
                  "fields": {
                    "DPIN": 8,
                    "MODE": "INPUT_PULLUP"
                  },
                  "next": {
                    "block": {
                      "type": "hw_forever",
                      "id": "m4udF+lf_rYL$2f|-]=o",
                      "inputs": {
                        "DO": {
                          "block": {
                            "type": "comm_serial_print",
                            "id": "r)CLvJC)a:|XNv2{l(jX",
                            "inputs": {
                              "VAL": {
                                "block": {
                                  "type": "text",
                                  "id": "wpJ[O3;-k8ffjh7XS,^T",
                                  "fields": {
                                    "TEXT": "Line/obstacle (HIGH=1): "
                                  }
                                }
                              }
                            },
                            "next": {
                              "block": {
                                "type": "comm_serial_println",
                                "id": "6Y)8SJhs;+gm/85izHR+",
                                "inputs": {
                                  "VAL": {
                                    "block": {
                                      "type": "sensor_digital_mblock",
                                      "id": "p}qn8:+$t6vQ+[]!0lwQ",
                                      "fields": {
                                        "DSTYPE": "PIR",
                                        "DPIN": 8
                                      }
                                    }
                                  }
                                },
                                "next": {
                                  "block": {
                                    "type": "hw_wait",
                                    "id": "~2mk][I|-N,4=Q}_^ooL",
                                    "fields": {
                                      "MS": 300
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
