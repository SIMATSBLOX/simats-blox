{
  "version": 1,
  "projectName": "Example: DHT22 temperature & humidity",
  "boardId": "esp32",
  "description": "DHT22 on GPIO15. Preview uses the machine/dht-style helpers. Allow 2 s between reads. Change the pin in blocks if your wiring differs.",
  "blockly": {
    "blocks": {
      "languageVersion": 0,
      "blocks": [
        {
          "type": "esp32_when_starts",
          "id": "N^~;:+J*G$]$~Dk+(_m-",
          "x": 20,
          "y": 20,
          "next": {
            "block": {
              "type": "comm_serial_begin",
              "id": "8^,z)r`s71mv$,be^!4w",
              "fields": {
                "BAUD": 115200
              },
              "next": {
                "block": {
